NEXT_PUBLIC_SUPABASE_URL=https://kgifsczgikzgeayueede.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ── Stripe ────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY   # webhook writes bypass RLS
# Six recurring prices — 2 cycles × 3 tiers (create these products in Stripe).
# Pro falls back to the legacy STRIPE_PRICE_MONTHLY/YEARLY if the PRO_* vars are unset.
STRIPE_PRICE_LIGHT_MONTHLY=price_...      # $5/mo
STRIPE_PRICE_LIGHT_YEARLY=price_...       # $50/yr
STRIPE_PRICE_PRO_MONTHLY=price_...        # $20/mo  (or set STRIPE_PRICE_MONTHLY)
STRIPE_PRICE_PRO_YEARLY=price_...         # $200/yr (or set STRIPE_PRICE_YEARLY)
STRIPE_PRICE_ACADEMY_MONTHLY=price_...    # $40/mo  (5 seats)
STRIPE_PRICE_ACADEMY_YEARLY=price_...     # $400/yr (5 seats)
# 1-hour demo booking link shown on /pricing and the landing (Calendly, etc).
NEXT_PUBLIC_DEMO_URL=https://calendly.com/your-handle/anglemotion-demo

# Google OAuth client for YouTube import flow
NEXT_PUBLIC_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID

# YouTube video loading: set this to your deployed Cloudflare Worker URL.
# The Worker resolves YouTube URLs and streams video bytes with CORS headers,
# ensuring the same IP resolves and fetches (avoids YouTube IP-lock 403s).
# Deploy workers/youtube-resolver/ to Cloudflare, then paste the URL here.
NEXT_PUBLIC_YT_RESOLVER_URL=https://coachlab-youtube-resolver.<your-account>.workers.dev

# Fallback: Vercel server-side resolution is used when the Worker is unavailable.
# Optional: comma-separated Piped API bases when direct extraction fails (see docs.piped.video API).
# YOUTUBE_PIPED_INSTANCES=https://pipedapi.kavin.rocks,https://pipedapi.syncpundit.com
# Set to 1 to disable third-party Piped fallback only (not recommended unless compliance requires it).
# YOUTUBE_DISABLE_PIPED_FALLBACK=0

